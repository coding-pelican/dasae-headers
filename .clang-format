## clang-format configurator v2 https://clang-format-configurator.site/
## see https://clang.llvm.org/docs/ClangFormatStyleOptions.html
---
BasedOnStyle: LLVM
Language: Cpp
Standard: c++20
ColumnLimit: 0
TabWidth: 4
IndentWidth: 4
IndentPPDirectives: None
IndentExternBlock: NoIndent
IndentGotoLabels: false
ObjCBlockIndentWidth: 4
LambdaBodyIndentation: OuterScope
AccessModifierOffset: -4
MaxEmptyLinesToKeep: 5
InsertNewlineAtEOF: true
# AlignAfterOpenBracket: Align
# AlignAfterOpenBracket: DontAlign
# AlignAfterOpenBracket: AlwaysBreak
AlignAfterOpenBracket: BlockIndent
AlignConsecutiveAssignments:
  Enabled: false
  # Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false
  # AcrossComments: true
  AlignCompound: false
  AlignFunctionPointers: false
  PadOperators: false
  # PadOperators: true
AlignConsecutiveBitFields:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: true
  AlignCompound: false
  AlignFunctionPointers: false
  PadOperators: true
AlignConsecutiveDeclarations:
  Enabled: false
  # Enabled: true
  AcrossEmptyLines: false
  # AcrossComments: true
  AcrossComments: false
  AlignCompound: false
  AlignFunctionPointers: false
  PadOperators: false
  # PadOperators: true
AlignConsecutiveMacros:
  Enabled: false
  # Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false
  # AcrossComments: true
  AlignCompound: false
  AlignFunctionPointers: false
  PadOperators: false
  # PadOperators: true
AlignConsecutiveShortCaseStatements:
  Enabled: false
  # Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false
  # AcrossComments: true
  AlignCaseArrows: false
  AlignCaseColons: false
AlignTrailingComments: false
SpacesBeforeTrailingComments: 1
AlignEscapedNewlines: DontAlign
AlignOperands: AlignAfterOperator
AllowShortBlocksOnASingleLine: Always
AllowShortIfStatementsOnASingleLine: AllIfsAndElse
AllowShortLoopsOnASingleLine: true
AllowShortCaseExpressionOnASingleLine: true
AllowShortCaseLabelsOnASingleLine: true
# BinPackArguments: false
BinPackArguments: true
# BinPackParameters: false
BinPackParameters: true

InsertBraces: false
# InsertBraces: true
BreakAfterAttributes: Leave
BreakBeforeBinaryOperators: All
BreakBeforeBraces: Custom
BraceWrapping:
  AfterCaseLabel: false
  AfterClass: false
  AfterControlStatement: Never
  AfterEnum: false
  AfterFunction: false
  AfterNamespace: false
  AfterObjCDeclaration: false
  AfterStruct: false
  AfterUnion: false
  AfterExternBlock: false
  BeforeCatch: false
  BeforeElse: false
  BeforeLambdaBody: false
  BeforeWhile: false
  IndentBraces: false
  SplitEmptyFunction: false
  SplitEmptyRecord: false
  SplitEmptyNamespace: false
# Cpp11BracedListStyle: true
Cpp11BracedListStyle: false
ConstructorInitializerAllOnOneLineOrOnePerLine: false
BreakConstructorInitializers: BeforeComma

# AlwaysBreakAfterReturnType: All
# ContinuationIndentWidth: 4

PointerAlignment: Left
SortIncludes: Never

Macros:
  - edittime_only(inner)="[](void) -> (void) inner"
  - comptime_only(inner)="[](void) -> (void) inner"
  - runtime_only(inner)="[](void) -> (void) inner"
  - dev_only(inner)="[](void) -> (void) inner"
  - debug_only(inner)="[](void) -> (void) inner"
  - release_only(inner)="[](void) -> (void) inner"
  - TEST_only(inner)="[](void) -> (void) inner"

  - "pp_then_(Then)=Then"
  - "pp_else_(Else)=Else"

  - "pp_switch_(Expr)=pp_exec_ignore Expr"
  - "pp_case_(Expr)=pp_exec_ignore Expr"
  - "pp_default_(Expr)=pp_exec_ignore Expr"

  - "T_switch$(Expr)=pp_exec_ignore Expr"
  - "T_decl$(Expr)=pp_exec_ignore Expr"
  - "T_impl$(Expr)=pp_exec_ignore Expr"
  - "T_use$(Expr)=pp_exec_ignore Expr"

  # - "let_(ident, T)=T const ident"
  # - "var_(ident, T)=T ident"

  - "$P_const$(T)=const T*"
  - "$P$(T)=T*"
  - "$A$(N,T)=T[N]"

  - "P_const$$(T)=P<const T>"
  - "P$$(T)=P<T>"
  - "P_const$(T)=P<const T>"
  - "P$(T)=P<T>"

  - "S_const$$(T)=S<const T>"
  - "S$$(T)=S<T>"
  - "S_const$(T)=S<const T>"
  - "S$(T)=S<T>"

  - "A$$(N,T)=TypeOf(T[N])"
  - "A$(N,T)=TypeOf(T[N])"

  - "O$$(T)=O<T>"
  - "O$(T)=O<T>"

  - "E$$(T)=E<T>"
  - "E$(T)=E<T>"

  # Operators
  - "n$(_T)=(_T)"
  # - "n_"
  - "l$(_T_Expr)=(_T_Expr)"
  - "l0$(_T)=(_T)"
  # - "initial$"
  # - "initial_"
  # - "cleared$"
  # - "cleared_"
  # - "copy_"
  # - "move_"
  # - "asg_"
  # - "asg_l"
  - "as$(_T)=(_T)"
  # - "to$"
  # - "into$"
  - "from$(_T_Expr)=(_T_Expr)"
  - "with_(_Expr)=pp_exec_ignore _Expr"

  # Casting Operators
  - "ptrToInt(_Expr)=(_Expr)"
  - "intToPtr$(_Expr)=(_Expr)"
  - "ptrCast$(_Expr)=(_Expr)"
  - "ptrAlignCast$(_Expr)=(_Expr)"
  - "ptrQualCast$(_Expr)=(_Expr)"
  - "ptrAlignQualCast$(_Expr)=(_Expr)"
  - "alignCast(_Expr)=(_Expr)"
  - "bitCast$(_Expr)=(_Expr)"
  - "intToBool$(_Expr)=(_Expr)"
  - "boolToInt$(_Expr)=(_Expr)"
  - "intCast$(_Expr)=(_Expr)"
  - "intToFlt$(_Expr)=(_Expr)"
  - "fltToInt$(_Expr)=(_Expr)"
  - "fltCast$(_Expr)=(_Expr)"

  # Function, Attribute, Scope
  - "$attr(Attrs)=(void)Attrs;"
  - "$static=static"
  - "$extern=extern"
  - "fn_(Expr)=static Expr"
  - "co_fn_(Expr)=static Expr"
  - "$un(keyword)=/**/pp_exec_expand"
  - "$unscoped(keyword)=/**/"
  - "$unguarded(keyword)=/**/"
  - "$end(keyword)=/**/"
  - "$deferral(keyword)=/**/"

  # Switch, Match
  - "enum_(_Expr)=pp_exec_ignore _Expr"
  - "variant_(_Expr)=pp_exec_ignore _Expr"
  - "switch_(init_cond)=switch (init_cond)"
  - "match_(_Expr)=switch (_Expr)"
  - "case_(_Enum)=case _Enum:"
  - "cases_(_Enums)=case _Enum: { pp_exec_expand(_Enums); }"
  - "pattern_(_Enum)=case _Enum:"
  - "patterns_(_Enums)=case _Enum: { pp_exec_expand(_Enums); }"
  - "default_(_Empty)=case _Empty otherwise:"

  # Control flow
  - "if_(init, cond)=if (init; cond)"
  - "else_(init)=else if (init; true)"
  - "while_(cond)=if (cond)"
  - "for_(_Expr)=if (_Expr)"
  - "hence_(_keyword)=_keyword"
  - "loop_labeled(_label, _stmt)_label: _stmt"
  - "pipe_(_Expr)=pp_exec_ignore _Expr"
  - "chain$(_Expr)=pp_exec_ignore _Expr"
  - "suspend_(_Expr)=pp_exec_ignore _Expr"

  # Optional value
  - "if_some(_Expr)=if (_Expr)"
  - "if_some_void(_Expr)=if (_Expr)"
  - "else_none=else"
  - "if_none(_Expr)=if (_Expr)"
  - "else_some(_Expr)=else if (_Expr)"
  - "else_some_void=else"
  - "while_some(_expr)=if (_expr)"
  - "while_none(_expr)=if (_expr)"

  # Error result
  - "errset_(_Expr)=pp_exec_ignore _Expr"
  - "if_ok(_Expr)=if (_Expr)"
  - "if_ok_void(_Expr)=if (_Expr)"
  - "else_err(_Expr)=else if (_Expr)"
  - "if_err(_Expr)=if (_Expr)"
  - "else_ok(_Expr)=else if (_Expr)"
  - "else_ok_void=else"
  - "while_ok(_expr)=if (_expr)"
  - "while_err(_expr)=if (_expr)"
  # - "blk_defer={ do"
  # - "blk_deferral=while(false); }"
  # - "blk_defer=("
  # - "blk_deferral=)"

  # - "return_(Expr)=return Expr"
  # - "return_void(Expr)=return Expr"

  # - "return_some(Expr)=return Expr"
  # - "return_some_void(Expr)=return Expr"
  # - "return_none(Expr)=return Expr"

  # - "return_ok(Expr)=return Expr"
  # - "return_ok_void(Expr)=return Expr"
  # - "return_err(Expr)=return Expr"

  # - "$break_(Expr)=return Expr"
  # - "$break_void(Expr)=return Expr"

  # - "$break_some(Expr)=return Expr"
  # - "$break_some_void(Expr)=return Expr"
  # - "$break_none(Expr)=return Expr"

  # - "$break_ok(Expr)=return Expr"
  # - "$break_ok_void(Expr)=return Expr"
  # - "$break_err(Expr)=return Expr"

AttributeMacros:
  - $attr

  - $ignore_void
  - $ignore

  - $nullable
  - $nonnull

  - $fallthrough
  # - $inline
  # - $inline_always
  # - $inline_never

  # - $on_load
  # - $on_exit

  # - $keep_symbol
  # - $maybe_unused
  # - $must_use
  # - $must_check
  # - $no_return

  # - $deprecated
  # - $deprecated_msg
  # - $deprecated_instead
